{
  "manifest_version": 3,
  "name": "OLP Custom Score & Subscription",
  "version": "1.0.0",
  "description": "Custom score modifier for OLP with subscription support.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "http://192.168.50.140/*",
    "https://app1.oceantg.com/*",
    "https://app.oceantg.com/*",
    "https://*.vercel.app/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://192.168.50.140/*",
        "https://app1.oceantg.com/*",
        "https://app.oceantg.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
